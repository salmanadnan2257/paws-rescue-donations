# Django secret key. Generate one with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-random-50-character-string

# "True" enables Django debug mode. Keep False in production.
DEBUG=True

# Comma-separated hostnames the site may be served from.
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection string. Leave empty to fall back to local SQLite.
DATABASE_URL=

# Email for the admin user created by `manage.py create_initial_admin`.
INITIAL_ADMIN_EMAIL=admin@example.com

# Password for that initial admin user. Change it after first login.
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
